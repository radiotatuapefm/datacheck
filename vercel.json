{
  "version": 2,
  "builds": [
    {
      "src": "datacheck-pro/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "datacheck-pro/frontend/dist"
      }
    },
    {
      "src": "datacheck-pro/backend/server/_core/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "datacheck-pro/backend/server/_core/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "datacheck-pro/frontend/dist/index.html"
    }
  ],
  "outputDirectory": "datacheck-pro/frontend/dist"
}

